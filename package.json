{
  "name": "schwankie",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "18.2.56",
    "concurrently": "^9.1.2",
    "drizzle-orm": "0.30.10",
    "prettier": "^3.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.4.5"
  },
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "scripts": {
    "dev": "concurrently bun:dev:api bun:dev:www",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:www": "bun run --cwd apps/www dev",
    "dev:ios": "bun run --cwd apps/mobile ios",
    "dev:tasks": "bun run --cwd apps/tasks dev",
    "build": "concurrently bun:build:*",
    "build:www": "cd apps/www && bun run build",
    "typecheck": "concurrently bun:typecheck:*",
    "typecheck:www": "cd apps/www && bun run typecheck",
    "typecheck:mobile": "cd apps/mobile && bun run type-check",
    "start": "concurrently bun:start:*",
    "start:api": "cd apps/api && bun run start",
    "start:www": "cd apps/www && bun run start",
    "start:tasks": "cd apps/tasks && bun run start",
    "tasks-runner": "bun run deploy/mac-mini/src/runner.ts",
    "test": "concurrently bun:test:*",
    "test:client": "bun test --cwd packages/client",
    "test:domain": "bun test --cwd packages/domain",
    "test:metadata": "bun test --cwd packages/metadata",
    "test:api": "bun test --cwd apps/api",
    "test:www": "bun test --cwd apps/www",
    "test:env": "bun test --cwd packages/env",
    "test:tasks": "bun test --cwd apps/tasks",
    "db:generate": "bun run --cwd packages/database generate",
    "db:migrate": "bun run --cwd packages/database migrate",
    "deploy:api": "fly deploy --config ./deploy/api/fly.toml --dockerfile ./deploy/api/Dockerfile",
    "deploy:www": "fly deploy --config ./deploy/www/fly.toml --dockerfile ./deploy/www/Dockerfile",
    "sync-secrets:api": "./scripts/sync-fly-secrets.sh apps/api schwankie-api",
    "sync-secrets:www": "./scripts/sync-fly-secrets.sh apps/www schwankie"
  }
}

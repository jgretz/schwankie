{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.schwankie.com",
        "EXPO_PUBLIC_API_KEY": "@EXPO_PUBLIC_API_KEY"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.schwankie.com",
        "EXPO_PUBLIC_API_KEY": "@EXPO_PUBLIC_API_KEY"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.schwankie.com",
        "EXPO_PUBLIC_API_KEY": "@EXPO_PUBLIC_API_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
